#!ipxe
# hw-validation -- PXE-booted stress test for the 6-node K8s cluster.
#
# Boots a custom Alpine Linux live image that stress-tests CPU / RAM /
# NVMe / SATA / both NICs with thermal telemetry, logs JSON to NAS NFS.
# Companion to bios-config (applies firmware settings) -- this validates
# the hardware those settings run on.
#
# Built in the sibling hw-validation repo:
#   cd ~/Documents/github/hw-validation && ./tools/build-image.sh
#   cd ~/Documents/github/truenas-infra && ./manage.sh phase apps --apply
#
# The builder emits build/latest/{vmlinuz-lts, initramfs-lts,
# modloop-lts, overlay.cpio.gz}. `phase apps --apply` uploads those to
# ${cache_url}/hw-validation/latest/ -- the URLs this menu references.
#
# Phase A (current): only the `quick` profile is wired up -- boots
# Alpine, runs the disk-safety guard smoke test against real disks
# (expects all refuses on a Talos-provisioned node), reboots. No
# destructive I/O, no stress load yet. Later phases add standard /
# burnin / shell / memtest86+ parallel entries.

:start
menu hw-validation -- stress test
item --gap -- --- Profiles ---
item quick     Phase A smoke test (guards round-trip on real disks, ~2 min)
item cpu       Phase B-alpha CPU stress (60s all-core + thermal telemetry)
item ram       Phase C RAM stress (60s stress-ng --vm --verify + telemetry)
item nvme      Phase C NVMe read (60s fio seq-read @ 1MB, guard-gated, read-only)
item ssd       Phase C SATA SSD read (60s fio seq-read @ 1MB, /dev/sda, read-only)
item net-mgmt  Phase C mgmt NIC (I219-LM 1Gb, iperf3 → NAS 10.10.5.10)
item --gap -- --- Advanced ---
item hold      Boot image, drop to shell (operator debug)
item --gap -- ---
item back      Back to main menu
choose --timeout 30000 --default quick target || goto back
goto ${target}

# ─── Kernel args ────────────────────────────────────────────────────
#
# Alpine netboot uses a STOCK initramfs that is just a bootstrap -- it
# has no /sbin/init of its own. At boot, Alpine's init script parses
# the kernel cmdline for:
#
#   modloop=<URL>      squashfs of kernel modules (sd-mod, nvme, etc.)
#   apkovl=<URL>       our overlay: scripts + /etc/apk/world + repositories
#   ip=dhcp            both NICs DHCP
#
# It fetches both over HTTP, untars the apkovl, then runs `apk add`
# against the repo listed in /etc/apk/repositories to install
# alpine-base + our packages. THAT creates /sbin/init. Only then does
# OpenRC run /etc/local.d/stresstest.start.
#
# Do NOT try to ship apkovl.tar.gz as a second `initrd` directive --
# the kernel would concatenate it with the stock initramfs (both cpio)
# and the tar inside would confuse the cpio loader. apkovl is HTTP.
#
# Cmdline contract with image/init/stresstest.start (hw-validation repo):
#   stress.profile=quick|standard|burnin|shell -- which profile runs
#   stress.role=server|client                  -- iperf3 pairing (Phase E+)
#   stress.duration=<seconds>                  -- overrides profile default
#   stress.destructive=1                       -- permit fio writes
#   stress.hold=1                              -- drop to shell instead of reboot
#
# Other Alpine live framework bits:
#   modules=loop,squashfs,sd-mod,usb-storage   -- load so modloop can mount
#   console=tty0                               -- visible on AMT KVM
#   video=1920x1080 nomodeset                  -- pin framebuffer to 1080p
#     The nodes use 4K passive HDMI dummy plugs (standardised fleet-wide
#     in bios-config v1.1.0). The iGPU reads their EDID and boots Linux
#     into a 3840x2160 framebuffer; AMT KVM then downscales that to its
#     ~1024x800 viewport, which leaves the console text sub-pixel
#     microscopic. `nomodeset` keeps i915's KMS off (we're not doing
#     anything graphical anyway), pinning the firmware efifb, and
#     `video=1920x1080` asks that efifb to initialise at 1080p --
#     readable in AMT KVM.
#
# Keep the base args identical across profiles so the only variable is
# stress.profile / stress.hold. Simplifies debugging.

:quick
echo Booting hw-validation quick profile (guard smoke test)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 stress.profile=quick
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:cpu
echo Booting hw-validation cpu profile (Phase B-alpha — 60s stress-ng all-core)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=cpu
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:ram
echo Booting hw-validation ram profile (Phase C — 60s stress-ng --vm --verify)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=ram
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:nvme
echo Booting hw-validation nvme profile (Phase C — 60s fio read-only seq-read)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=nvme
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:ssd
echo Booting hw-validation ssd profile (Phase C — 60s fio read-only seq-read on /dev/sda)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=ssd
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:net-mgmt
# Single-entry design: the NAS runs an always-on iperf3 server
# container (apps/iperf3/) bound to 10.10.5.10:5201. Every fleet node
# targets that — no pair-node orchestration, no operator-typed IP.
# If the NAS-side service is down, check `docker logs iperf3` on the
# NAS; `phase apps --apply` (re)deploys it.
echo Booting hw-validation net-mgmt profile (Phase C — iperf3 -c 10.10.5.10 via I219-LM)...
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=net-mgmt
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

:hold
echo Booting hw-validation with stress.hold=1 -- drops to shell after init
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 stress.profile=quick stress.hold=1
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

# ─── Failure handling ───────────────────────────────────────────────

:fail
echo
echo ERROR: hw-validation boot failed. Possible causes:
echo   * ${cache_url}/hw-validation/latest/vmlinuz-lts 404 --
echo     sibling hw-validation build artefact not uploaded.
echo     Fix: cd ~/Documents/github/hw-validation
echo          ./tools/build-image.sh
echo          cd ../truenas-infra && ./manage.sh phase apps --apply
echo
echo   * modloop-lts failed to fetch --
echo     curl -I ${cache_url}/hw-validation/latest/modloop-lts
echo
echo   * apkovl.tar.gz fetch failed, or alpine_repo unreachable --
echo     curl -I ${cache_url}/hw-validation/latest/apkovl.tar.gz
echo     (and check the node's mgmt-VLAN internet access -- the
echo      netboot init pulls ~15 MB from dl-cdn.alpinelinux.org)
echo
echo Runbook: https://wiki.w1.lv/runbooks/hw-validation/  (Phase F)
echo
prompt Press any key to return to the main menu...
goto back

:back
exit
