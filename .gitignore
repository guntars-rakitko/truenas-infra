# Credentials (plaintext — never commit)
.env
apps/*/.env
apps/*/secrets.yaml
# .env.sops and apps/*/secrets.sops.yaml are SOPS-encrypted and safe to commit

# Backups (local only)
backups/
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
dist/
build/
# Exception: apps/pxe/build/ is the container build context (Dockerfile
# + iPXE build inputs), not Python build output — must ship.
!apps/pxe/build/
!apps/pxe/build/**

# uv
.uv/

# OS
.DS_Store
