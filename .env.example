# ─── TrueNAS API ──────────────────────────────────────────────────────────────
# Fill these in AFTER the manual bootstrap in bootstrap/01-bootstrap-notes.md.
# Real values live in .env.sops (SOPS-encrypted); .env is rendered at apply time.

# Hostname (not IP) since phase 3 tls is done — the wildcard *.w1.lv cert
# on nas.w1.lv validates, and verify_ssl=true closes the man-in-the-middle
# risk on the mgmt VLAN. To bootstrap when DNS is broken, temporarily set
# TRUENAS_HOST=10.10.5.10 + TRUENAS_VERIFY_SSL=false in .env (not .env.sops).
TRUENAS_HOST=nas.w1.lv
TRUENAS_API_KEY=
TRUENAS_VERIFY_SSL=true

# ─── SSH (fallback, optional) ─────────────────────────────────────────────────
TRUENAS_SSH_USER=svc-automation
TRUENAS_SSH_KEY_PATH=~/.ssh/id_ed25519

# ─── CloudFlare ACME DNS-01 ───────────────────────────────────────────────────
# Required for phase 3 (tls). Create at dash.cloudflare.com →
# My Profile → API Tokens → Custom token with:
#   Permissions: Zone:Zone:Read + Zone:DNS:Edit
#   Zone Resources: Include / Specific zone / w1.lv
# Used by TrueNAS's built-in ACME client to publish _acme-challenge TXT
# records during DNS-01 validation. Stored in .env.sops only (never .env).
CLOUDFLARE_API_TOKEN=

# ─── Runtime knobs ────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Default is dry-run; pass --apply to actually change state.
APPLY=false
