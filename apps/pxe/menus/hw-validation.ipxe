#!ipxe
# hw-validation -- PXE-booted stress test for the 6-node K8s cluster.
#
# Boots a custom Alpine Linux live image that stress-tests CPU / RAM /
# NVMe / SATA / both NICs with thermal telemetry, uploads a JSON report
# to NAS NFS. Companion to bios-config (applies firmware settings) --
# this validates the hardware those settings run on.
#
# Built in the sibling hw-validation repo:
#   cd ~/Documents/github/hw-validation && ./tools/build-image.sh
#   cd ~/Documents/github/truenas-infra && ./manage.sh phase apps --apply
#
# ─── Menu structure ─────────────────────────────────────────────────
#
# Two-level: top menu picks the profile, then a sub-menu picks the
# duration. The only value injected into the kernel cmdline is
# stress.profile=${profile} stress.duration=${duration} -- a single
# shared :boot-image label does the actual netboot, avoiding duplicate
# kernel/initrd lines for each (profile × duration) combination.
#
# Duration accounting — CRITICAL for setting operator expectations:
#   * Single-component read-only (cpu/ram/nvme/ssd/net-*):
#       picked duration = wall time.
#   * Single-component destructive (nvme-write/ssd-write):
#       read matrix THEN write matrix, each using STRESS_DURATION
#       → wall time ~= 2 × picked.
#   * Sequential `all`:
#       six components back-to-back, each getting STRESS_DURATION
#       → wall time ~= 6 × picked (10 min picked = ~60 min run).
#   * Concurrent `burnin`:
#       all six in parallel → picked duration = wall time.
#   * Concurrent + destructive `disk-burnin`:
#       both drives concurrent, but each does read+write
#       → wall time ~= 2 × picked.
#
# The submenus below hardcode these totals into each item label so the
# operator sees the real wall time before committing. Separate :pick_*
# labels per mode avoid relying on iPXE variable-expansion tricks that
# don't actually work (iPXE's ${name:type} only does type conversion,
# not bash-style ${name:+value} fallback).
#
# Profiles:
#   safety        Disk-safety guards round-trip; no stress, no I/O load.
#                 Fixed ~2 min; no duration submenu.
#   cpu, ram, nvme, ssd, net-mgmt, net-data
#                 Single-component stress. Duration submenu: 1/10/30/60 min.
#   all           Sequential run of all six components. Each component
#                 gets STRESS_DURATION seconds → total is ~6× picked.
#   burnin        Concurrent run of all six. Picked duration = total.
#
# Destructive tier (writes to NVMe / SATA -- requires disk already wipe'd):
#   nvme-write, ssd-write, disk-burnin
#                 Carry stress.destructive=1. Still guard-gated -- a
#                 drive with any signature or partition table is refused
#                 up-front. Operator wipes the drive explicitly before
#                 running these (stress.profile=safety's round-trip does
#                 exactly that). Write matrix size-capped at ~50 GiB
#                 per drive per full run (see scripts/lib/fio-matrix.sh).
#
# ─── Kernel args ────────────────────────────────────────────────────
#
# Alpine netboot uses a stock initramfs as bootstrap. At boot it parses
# the cmdline for:
#   modloop=<URL>      squashfs of kernel modules
#   apkovl=<URL>       our overlay: scripts + /etc/apk/world + repositories
#   ip=dhcp            both NICs DHCP
#
# stresstest.start reads the stress.* keys to pick profile, duration,
# destructive mode, hold-for-shell, and debug verbosity:
#   stress.profile=safety|cpu|ram|nvme|ssd|net-mgmt|net-data|all|burnin
#                                              |nvme-write|ssd-write|disk-burnin
#   stress.duration=<seconds>                  override default 60s
#   stress.destructive=1                       permit fio writes
#   stress.hold=1                              drop to shell after run
#   stress.debug=1                             verbose modloop/PCI/hwmon dumps
#
# Other Alpine live framework bits (same across all entries):
#   modules=loop,squashfs,sd-mod,usb-storage   load so modloop can mount
#   console=tty0                               visible on AMT KVM
#   video=1920x1080 nomodeset                  pin efifb to 1080p for AMT KVM
#                                              readability (fleet uses 4K
#                                              passive HDMI dummy plugs)
#   acpi_enforce_resources=lax                 lets it87/nct6775 bind despite
#                                              ACPI-claimed Super I/O ports

:start
menu hw-validation -- stress test
item --gap -- --- Safety ---
item safety     Disk-safety guards round-trip (~2 min, no stress)
item --gap -- --- Single-component (picked duration = wall time) ---
item cpu        CPU stress (all cores)
item ram        RAM stress + verify
item nvme       NVMe read matrix (seq 1M, seq 64k, rand 4k qd32/qd1)
item ssd        SATA SSD read matrix (same 4 stages)
item net-mgmt   Mgmt NIC  (I219-LM 1Gb iperf3 -> NAS)
item net-data   Data NIC  (I226-V 2.5Gb iperf3 -> NAS)
item --gap -- --- Combined ---
item all        All 6 components SEQUENTIAL (~6x picked duration total)
item burnin     All 6 components CONCURRENT (picked duration = wall time)
item --gap -- --- Destructive (bringup only -- writes up to ~50 GiB/drive) ---
item nvme-write   [!] NVMe read + write matrix (~2x picked; writes ~50 GiB)
item ssd-write    [!] SATA SSD read + write matrix (~2x picked; writes ~50 GiB)
item disk-burnin  [!] Both drives concurrent, read + write (~2x picked)
item --gap -- --- Advanced ---
item hold       Boot to shell (no stress, operator debug)
item --gap -- ---
item back       Back to main menu
choose --timeout 30000 --default cpu target || goto back
goto ${target}

# ─── Profile selection: set vars, route to correct duration picker ──
#
# Five pickers: read-only single, read+write single, sequential, concurrent,
# concurrent+destructive. Each hardcodes the wall-time math in its labels so
# the operator sees "10 min picked = ~60 min total" before committing.

:safety     set profile safety    && set duration 120 && goto boot-image
:cpu        set profile cpu       && goto pick_ro
:ram        set profile ram       && goto pick_ro
:nvme       set profile nvme      && goto pick_ro
:ssd        set profile ssd       && goto pick_ro
:net-mgmt   set profile net-mgmt  && goto pick_ro
:net-data   set profile net-data  && goto pick_ro
:all        set profile all       && goto pick_seq
:burnin     set profile burnin    && goto pick_con

# Destructive entries — set profile AND stress.destructive=1. Each routes
# to a submenu that accounts for the read-then-write ~2x doubling in labels.
:nvme-write    set profile nvme   && set destructive 1 && goto pick_rw
:ssd-write     set profile ssd    && set destructive 1 && goto pick_rw
:disk-burnin   set profile burnin && set destructive 1 && goto pick_con_rw

# ─── Duration submenus ──────────────────────────────────────────────
#
# Shared time-setter labels (d-1m / d-10m / d-30m / d-60m). Each picker
# below surfaces different totals to the operator — the underlying
# stress.duration value is identical across pickers.

# Read-only single-component (cpu / ram / nvme / ssd / net-mgmt / net-data):
# wall time = picked duration.
:pick_ro
menu duration for ${profile}  (single component, wall time = picked)
item d-1m    1 min
item d-10m   10 min
item d-30m   30 min
item d-60m   60 min
item back    <- back to main menu
choose --default d-10m durtarget || goto start
goto ${durtarget}

# Read+write single-component (nvme-write / ssd-write): fio runs the
# 4-stage read matrix (STRESS_DURATION total) THEN the 4-stage write
# matrix (another STRESS_DURATION). Wall time ~= 2x picked.
:pick_rw
menu duration for ${profile}  (DESTRUCTIVE - read then write, ~2x wall time)
item d-1m    1 min read + 1 min write    (~2 min total)
item d-10m   10 min read + 10 min write  (~20 min total)
item d-30m   30 min read + 30 min write  (~60 min total)
item d-60m   60 min read + 60 min write  (~2 h total)
item back    <- back to main menu
choose --default d-10m durtarget || goto start
goto ${durtarget}

# Sequential `all`: six components back-to-back, each gets STRESS_DURATION.
# Wall time ~= 6x picked.
:pick_seq
menu duration for 'all'  (SEQUENTIAL - 6 components back-to-back, ~6x wall time)
item d-1m    1 min per component   (~6 min total)
item d-10m   10 min per component  (~1 h total)
item d-30m   30 min per component  (~3 h total)
item d-60m   60 min per component  (~6 h total)
item back    <- back to main menu
choose --default d-10m durtarget || goto start
goto ${durtarget}

# Concurrent `burnin`: all six in parallel. Picked duration = wall time.
:pick_con
menu duration for 'burnin'  (CONCURRENT - all 6 in parallel, wall time = picked)
item d-1m    1 min total
item d-10m   10 min total
item d-30m   30 min total
item d-60m   1 h total
item back    <- back to main menu
choose --default d-10m durtarget || goto start
goto ${durtarget}

# Concurrent + destructive `disk-burnin`: both drives in parallel, each
# doing read+write = ~2x picked.
:pick_con_rw
menu duration for 'disk-burnin'  (CONCURRENT + DESTRUCTIVE - ~2x wall time)
item d-1m    1 min read + 1 min write    (~2 min total)
item d-10m   10 min read + 10 min write  (~20 min total)
item d-30m   30 min read + 30 min write  (~60 min total)
item d-60m   60 min read + 60 min write  (~2 h total)
item back    <- back to main menu
choose --default d-10m durtarget || goto start
goto ${durtarget}

:d-1m     set duration 60    && goto boot-image
:d-10m    set duration 600   && goto boot-image
:d-30m    set duration 1800  && goto boot-image
:d-60m    set duration 3600  && goto boot-image

# ─── Shared netboot label ───────────────────────────────────────────
#
# One kernel/initrd pair serves every (profile × duration) combination.
# ${destructive} is unset for read-only runs and set to 1 for the
# destructive tier; iPXE substitutes empty string on unset vars, so
# the kernel line is well-formed either way -- stress.destructive=
# with empty value reads the same as absent in stresstest.start's
# kcmdline parser.

:boot-image
echo Booting hw-validation: profile=${profile} duration=${duration}s destructive=${destructive}
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 acpi_enforce_resources=lax stress.profile=${profile} stress.duration=${duration} stress.destructive=${destructive}
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

# ─── Debug / hold ───────────────────────────────────────────────────

:hold
echo Booting hw-validation with stress.hold=1 -- drops to shell after init
imgfree
kernel ${cache_url}/hw-validation/latest/vmlinuz-lts modules=loop,squashfs,sd-mod,usb-storage modloop=${cache_url}/hw-validation/latest/modloop-lts apkovl=${cache_url}/hw-validation/latest/apkovl.tar.gz ip=dhcp console=tty0 nomodeset video=1920x1080 stress.profile=safety stress.hold=1
initrd ${cache_url}/hw-validation/latest/initramfs-lts
boot || goto fail

# ─── Failure handling ───────────────────────────────────────────────

:fail
echo
echo ERROR: hw-validation boot failed. Possible causes:
echo   * ${cache_url}/hw-validation/latest/vmlinuz-lts 404 --
echo     sibling hw-validation build artefact not uploaded.
echo     Fix: cd ~/Documents/github/hw-validation
echo          ./tools/build-image.sh
echo          cd ../truenas-infra && ./manage.sh phase apps --apply
echo
echo   * modloop-lts failed to fetch --
echo     curl -I ${cache_url}/hw-validation/latest/modloop-lts
echo
echo   * apkovl.tar.gz fetch failed, or alpine_repo unreachable --
echo     curl -I ${cache_url}/hw-validation/latest/apkovl.tar.gz
echo     (and check the node's mgmt-VLAN internet access -- the
echo      netboot init pulls ~15 MB from dl-cdn.alpinelinux.org)
echo
echo Runbook: https://wiki.w1.lv/runbooks/hw-validation/
echo
prompt Press any key to return to the main menu...
goto back

:back
exit
